# ============================================================================
# KZDI Talent OS — Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================================

# Azure Foundry IQ Configuration
# Get from Azure Portal → Your Foundry resource → Keys → Primary API Key
FOUNDRY_IQ_KEY=sk-your-primary-api-key-here

# Azure Foundry Endpoint
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-id>/agents/<agent-id>
FOUNDRY_IQ_ENDPOINT=https://kzdi-talent-os-foundry-resource.services.ai.azure.com/api/projects/kzdi-talent-os-foundry/agents/kzdi-talent-os

# Supabase Configuration
# Get from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://qpooqpcjmbwkzjeyczxs.supabase.co
SUPABASE_KEY=your-supabase-public-anon-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# Telegram Notifications
# Get from BotFather on Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ADMIN_CHAT_ID=your-chat-id-here

# Feature Flags
ENABLE_TELEGRAM_NOTIFICATIONS=true
ENABLE_SUPABASE_LOGGING=true
DRY_RUN=false

# Environment
NODE_ENV=development
DEBUG=false

# Observability
LOG_LEVEL=info

